<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="480.0" prefWidth="800.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oyeshi_fabiha.careerbridge2.AdminLoginController">

    <VBox alignment="CENTER" prefWidth="380.0" spacing="10.0"
          style="-fx-background-color: linear-gradient(to bottom, #6C63FF, #4834d4);">
        <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/></padding>
        <Text text="CareerBridge" style="-fx-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
        <Text text="Alumni &amp; Mentor Portal" style="-fx-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;"/>
        <VBox spacing="20.0" style="-fx-padding: 40 0 0 0;">
            <VBox spacing="6.0">
                <Text text="🧑‍💼" style="-fx-font-size: 40px;"/>
                <Text text="Mentor Students" style="-fx-fill: #e2e8f0; -fx-font-size: 14px;"/>
            </VBox>
            <VBox spacing="6.0">
                <Text text="📢" style="-fx-font-size: 40px;"/>
                <Text text="Post Job Opportunities" style="-fx-fill: #e2e8f0; -fx-font-size: 14px;"/>
            </VBox>
            <VBox spacing="6.0">
                <Text text="✍️" style="-fx-font-size: 40px;"/>
                <Text text="Share Your Success Story" style="-fx-fill: #e2e8f0; -fx-font-size: 14px;"/>
            </VBox>
        </VBox>
    </VBox>

    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="20.0"
          style="-fx-background-color: #f8fafc;">
        <padding><Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/></padding>

        <VBox spacing="6.0">
            <Text text="Alumni Login" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-fill: #1a202c;"/>
            <Text text="Sign in to your alumni account" style="-fx-fill: #718096; -fx-font-size: 13px;"/>
        </VBox>

        <VBox spacing="14.0" maxWidth="320.0">
            <VBox spacing="5.0">
                <Label text="Username" style="-fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="usernameField" promptText="Enter username"
                           style="-fx-background-radius: 10; -fx-padding: 10; -fx-border-color: #e2e8f0;
                                  -fx-border-radius: 10; -fx-background-color: white;"/>
            </VBox>
            <VBox spacing="5.0">
                <Label text="Password" style="-fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <PasswordField fx:id="passwordField" promptText="Enter password"
                               style="-fx-background-radius: 10; -fx-padding: 10; -fx-border-color: #e2e8f0;
                                      -fx-border-radius: 10; -fx-background-color: white;"/>
            </VBox>

            <Button text="Login →" onAction="#handleAdminLogin" maxWidth="Infinity"
                    style="-fx-background-color: #6C63FF; -fx-text-fill: white; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px; -fx-cursor: hand;">
                <VBox.margin><Insets top="6.0"/></VBox.margin>
            </Button>

            <HBox alignment="CENTER" spacing="5.0">
                <Label text="New alumni?" style="-fx-text-fill: #718096;"/>
                <Hyperlink text="Register here" onAction="#handleAdminRegister"
                           style="-fx-text-fill: #6C63FF; -fx-font-weight: bold;"/>
            </HBox>
            <HBox alignment="CENTER">
                <Hyperlink text="← Back to Home" onAction="#handleBack"
                           style="-fx-text-fill: #a0aec0;"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
