<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" prefHeight="460.0" prefWidth="650.0" spacing="30.0"
      style="-fx-background-color: linear-gradient(to bottom right, #1a1a2e, #16213e, #0f3460);"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oyeshi_fabiha.careerbridge2.HelloController">

   <padding><Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/></padding>

   <VBox alignment="CENTER" spacing="8.0">
      <Text text="CareerBridge" style="-fx-fill: white; -fx-font-weight: bold;">
         <font><Font name="System Bold" size="44.0"/></font>
      </Text>
      <Text text="Connecting Students with Alumni, Opportunities &amp; Mentors"
            style="-fx-fill: #a0aec0; -fx-text-alignment: center;">
         <font><Font size="14.0"/></font>
      </Text>
   </VBox>

   <fx:define>
      <ToggleGroup fx:id="roleGroup"/>
   </fx:define>

   <VBox alignment="CENTER" spacing="16.0" maxWidth="320.0"
         style="-fx-background-color: rgba(255,255,255,0.07); -fx-background-radius: 20;
                 -fx-padding: 36; -fx-border-color: rgba(255,255,255,0.12);
                 -fx-border-radius: 20; -fx-border-width: 1;">
      <Text text="Who are you?" style="-fx-fill: #e2e8f0; -fx-font-size: 16px;"/>

      <RadioButton fx:id="alumniRadio" text="🎓  I am an Alumni"
                   toggleGroup="$roleGroup" onAction="#handleRoleSelection"
                   style="-fx-font-size: 16px; -fx-text-fill: white; -fx-cursor: hand;"/>

      <RadioButton fx:id="studentRadio" text="📚  I am a Student"
                   toggleGroup="$roleGroup" onAction="#handleRoleSelection"
                   style="-fx-font-size: 16px; -fx-text-fill: white; -fx-cursor: hand;"/>
   </VBox>

   <Text text="CareerBridge © 2026 — Oyeshi &amp; Fabiha" style="-fx-fill: #4a5568; -fx-font-size: 11px;"/>
</VBox>
