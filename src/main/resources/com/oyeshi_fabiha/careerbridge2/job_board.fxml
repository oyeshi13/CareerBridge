<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox spacing="20.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
    <children>
        <Label text="Recommended Jobs" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />

        <VBox spacing="15.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #E0E0E0; -fx-border-radius: 15;">
                    <children>
                        <VBox prefWidth="50.0" prefHeight="50.0" style="-fx-background-color: #E8F4FD; -fx-background-radius: 10; -fx-alignment: center;">
                            <children><Label text="J" style="-fx-font-weight: bold; -fx-text-fill: #3498DB;" /></children>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="5.0">
                            <children>
                                <Label text="Junior Data Analyst" style="-fx-font-weight: bold; -fx-font-size: 16;" />
                                <Label text="DataCorp Inc. • Remote • $70k - $90k" style="-fx-text-fill: #7F8C8D;" />
                            </children>
                        </VBox>
                        <Button style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-background-radius: 20;" text="Apply Now" onAction=""/>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #E0E0E0; -fx-border-radius: 15;">
                    <children>
                        <VBox prefWidth="50.0" prefHeight="50.0" style="-fx-background-color: #FEF9E7; -fx-background-radius: 10; -fx-alignment: center;">
                            <children><Label text="S" style="-fx-font-weight: bold; -fx-text-fill: #F1C40F;" /></children>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="5.0">
                            <children>
                                <Label text="Product Management Intern" style="-fx-font-weight: bold; -fx-font-size: 16;" />
                                <Label text="StartupX • New York, NY • Paid" style="-fx-text-fill: #7F8C8D;" />
                            </children>
                        </VBox>
                        <Button style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-background-radius: 20;" text="Apply Now" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>