<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20.0" style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oyeshi_fabiha.careerbridge2.storiesController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/></padding>

    <VBox spacing="4.0">
        <Text text="Alumni Success Stories" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-fill: #1a202c;"/>
        <Text text="Real journeys from our alumni community." style="-fx-fill: #718096; -fx-font-size: 13px;"/>
    </VBox>

    <ScrollPane fitToWidth="true" prefHeight="320.0"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox fx:id="storiesContainer" spacing="14.0" style="-fx-background-color: transparent;"/>
    </ScrollPane>

    <Separator style="-fx-background-color: #e2e8f0;"/>

    <!-- postPanel is shown only to alumni/admin -->
    <VBox fx:id="postPanel" spacing="12.0"
          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 22;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 3);
                 -fx-border-color: #e2e8f0; -fx-border-radius: 16;">
        <Text text="✍️  Share Your Story" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-fill: #2d3748;"/>

        <TextField fx:id="nameInput" promptText="Your Name — e.g. Tamanna Haque, Class of 2022"
                   style="-fx-background-radius: 10; -fx-padding: 10; -fx-border-color: #e2e8f0;
                          -fx-border-radius: 10; -fx-background-color: #f8fafc;"/>

        <TextArea fx:id="storyInput"
                  promptText="Tell students about your career journey, what helped you, and your advice..."
                  prefHeight="100.0" wrapText="true"
                  style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;
                         -fx-background-color: #f8fafc;"/>

        <Button fx:id="submitBtn" text="🚀  Post My Story" onAction="#handleAddStory"
                style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-background-radius: 10; -fx-padding: 10 24; -fx-cursor: hand; -fx-font-size: 13px;"/>
    </VBox>
</VBox>
