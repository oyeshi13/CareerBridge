<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="520.0" prefWidth="820.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oyeshi_fabiha.careerbridge2.RegisterController">

   <VBox alignment="CENTER" prefWidth="300.0"
         style="-fx-background-color: linear-gradient(to bottom, #0f3460, #16213e);">
      <padding><Insets bottom="40.0" left="30.0" right="30.0" top="40.0"/></padding>
      <Text text="Join CareerBridge" style="-fx-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
      <TextArea text="Create your student account and start connecting with alumni mentors today."
            style="-fx-fill: #a0aec0; -fx-font-size: 13px;" wrapText="true">
         <VBox.margin><Insets top="12.0"/></VBox.margin>
      </TextArea>
   </VBox>

   <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="16.0"
         style="-fx-background-color: #f8fafc;">
      <padding><Insets bottom="40.0" left="50.0" right="50.0" top="40.0"/></padding>

      <Text text="Student Registration" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-fill: #1a202c;"/>

      <GridPane hgap="16.0" vgap="12.0" maxWidth="460.0">
         <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
         </columnConstraints>

         <Label text="Full Name *" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                GridPane.columnIndex="0" GridPane.rowIndex="0"/>
         <TextField fx:id="nameField" promptText="Your full name"
                    style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                    GridPane.columnIndex="0" GridPane.rowIndex="1"/>

         <Label text="Phone Number" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                GridPane.columnIndex="1" GridPane.rowIndex="0"/>
         <TextField fx:id="phoneField" promptText="01XXXXXXXXX"
                    style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                    GridPane.columnIndex="1" GridPane.rowIndex="1"/>

         <Label text="Email Address *" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                GridPane.columnIndex="0" GridPane.rowIndex="2"/>
         <TextField fx:id="emailField" promptText="your@email.com"
                    style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                    GridPane.columnIndex="0" GridPane.rowIndex="3"/>

         <Label text="Password *" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                GridPane.columnIndex="1" GridPane.rowIndex="2"/>
         <PasswordField fx:id="passField" promptText="Create a password"
                        style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                        GridPane.columnIndex="1" GridPane.rowIndex="3"/>

         <Label text="Department" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                GridPane.columnIndex="0" GridPane.rowIndex="4"/>
         <TextField fx:id="deptField" promptText="e.g. CSE, EEE"
                    style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                    GridPane.columnIndex="0" GridPane.rowIndex="5"/>

         <Label text="Batch / Year" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                GridPane.columnIndex="1" GridPane.rowIndex="4"/>
         <TextField fx:id="batchField" promptText="e.g. 2024"
                    style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                    GridPane.columnIndex="1" GridPane.rowIndex="5"/>
      </GridPane>

      <HBox spacing="12.0" maxWidth="460.0">
         <Button text="Create Account" onAction="#handleRegister" HBox.hgrow="ALWAYS"
                 style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-padding: 11; -fx-font-size: 14px; -fx-cursor: hand;"/>
         <Button text="← Back to Login" onAction="#handleBackToLogin"
                 style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-padding: 11; -fx-cursor: hand;"/>
      </HBox>
   </VBox>
</HBox>
