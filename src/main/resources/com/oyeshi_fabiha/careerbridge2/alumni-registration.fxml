<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="600.0" prefWidth="880.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oyeshi_fabiha.careerbridge2.RegisterController">

    <VBox alignment="CENTER" prefWidth="300.0"
          style="-fx-background-color: linear-gradient(to bottom, #6C63FF, #4834d4);">
        <padding><Insets bottom="40.0" left="30.0" right="30.0" top="40.0"/></padding>
        <Text text="Alumni Registration" style="-fx-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        <TextArea text="Join as a mentor. Share your experience, post jobs, and inspire the next generation."
              style="-fx-fill: rgba(255,255,255,0.8); -fx-font-size: 13px;" wrapText="true">
            <VBox.margin><Insets top="12.0"/></VBox.margin>
        </TextArea>
    </VBox>

    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS"
                style="-fx-background-color: #f8fafc; -fx-background: #f8fafc;">
        <VBox alignment="CENTER" spacing="16.0" style="-fx-background-color: #f8fafc;">
            <padding><Insets bottom="40.0" left="50.0" right="50.0" top="40.0"/></padding>

            <Text text="Create Alumni Account" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-fill: #1a202c;"/>

            <GridPane hgap="16.0" vgap="12.0" maxWidth="480.0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <Label text="Full Name *" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="alumniNameField" promptText="John Doe"
                           style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                <Label text="Email Address" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <TextField fx:id="alumniEmailField" promptText="john@example.com"
                           style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Graduation Year" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                       GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="yearField" promptText="e.g. 2022"
                           style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                           GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                <Label text="Major / Department" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <TextField fx:id="majorField" promptText="Computer Science"
                           style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Current Company" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                       GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <TextField fx:id="companyField" promptText="e.g. Google"
                           style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                           GridPane.columnIndex="0" GridPane.rowIndex="5"/>

                <Label text="Current Position" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                       GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <TextField fx:id="positionField" promptText="Software Engineer"
                           style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                           GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                <Label text="Username *" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                       GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                <TextField fx:id="regUsernameField" promptText="Choose a username"
                           style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                           GridPane.columnIndex="0" GridPane.rowIndex="7"/>

                <Label text="Password *" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #4a5568;"
                       GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                <PasswordField fx:id="regPasswordField" promptText="Create a password"
                               style="-fx-background-radius: 8; -fx-padding: 9; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white;"
                               GridPane.columnIndex="1" GridPane.rowIndex="7"/>
            </GridPane>

            <HBox spacing="12.0" maxWidth="480.0">
                <Button text="Register as Alumni" onAction="#handleAdminRegister" HBox.hgrow="ALWAYS"
                        style="-fx-background-color: #6C63FF; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 10; -fx-padding: 11; -fx-font-size: 14px; -fx-cursor: hand;"/>
                <Button text="← Back to Login" onAction="#handleBackToAdminLogin"
                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568; -fx-font-weight: bold;
                               -fx-background-radius: 10; -fx-padding: 11; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </ScrollPane>
</HBox>
