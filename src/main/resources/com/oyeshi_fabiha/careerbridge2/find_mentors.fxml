<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20.0" style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oyeshi_fabiha.careerbridge2.FindMentorsController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="16.0">
        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
            <Text text="Find a Mentor" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-fill: #1a202c;"/>
            <Label fx:id="resultCountLabel" text="" style="-fx-text-fill: #718096; -fx-font-size: 13px;"/>
        </VBox>
        <HBox spacing="8.0" alignment="CENTER">
            <TextField fx:id="searchField" promptText="🔍  Search by name, company, major, year..."
                       prefWidth="320.0"
                       style="-fx-background-radius: 20; -fx-padding: 10 16; -fx-background-color: white;
                              -fx-border-color: #e2e8f0; -fx-border-radius: 20; -fx-font-size: 13px;"/>
        </HBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <FlowPane fx:id="mentorGrid" hgap="20.0" vgap="20.0"
                  style="-fx-background-color: transparent; -fx-padding: 4;"/>
    </ScrollPane>
</VBox>
